# Choose any model supported by your provider.
# Examples:
# - OpenAI: gpt-4o-mini (requires OPENAI_API_KEY)
# - Anthropic: claude-sonnet-4-6 (requires ANTHROPIC_API_KEY)
MODEL=gpt-4o-mini

# Optional defaults for the CLI user context:
DEFAULT_LOCATION=Prague

# Provider API keys (set the one that matches your MODEL):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model config
TEMPERATURE=0
MAX_TOKENS=800
TIMEOUT_SECONDS=30

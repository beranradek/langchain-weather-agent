# Choose an OpenAI model.
# Example: gpt-4o-mini (requires OPENAI_API_KEY)
MODEL=gpt-4o-mini

# Optional defaults for the CLI user context:
DEFAULT_LOCATION=Prague

# Weather tool HTTP timeout (Open-Meteo), in seconds:
TIMEOUT_SECONDS=30

# OpenAI API key:
OPENAI_API_KEY=

# Optional model config
TEMPERATURE=0
MAX_TOKENS=800

# Optional debug mode (prints full stack traces / HTTP error bodies):
DEBUG=0
